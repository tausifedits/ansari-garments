# Port the server will run on (defaults to 3000)
PORT=3000

# Node Environment: set to 'production' on deployment host (e.g. Render)
NODE_ENV=production

# MongoDB Atlas connection string (required in production)
MONGODB_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/dbname

# Admin access key for authorization (required in production)
ADMIN_ACCESS_KEY=YourSecureAdminAccessKeyHere
